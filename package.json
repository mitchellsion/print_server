{
  "name": "print_server",
  "version": "1.0.0",
  "description": "Local HTTPS bridge between browsers and POS printers (QZTray-style)",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node --import tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "build": "esbuild src/index.ts --bundle --platform=node --target=node22 --external:usb --format=cjs --outfile=build/bundle.cjs",
    "package": "node scripts/build-sea.mjs",
    "trust-cert": "tsx scripts/trust-cert.ts",
    "test": "node --import tsx --test src/**/*.test.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.18.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "usb"
    ]
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/static": "^9.1.3",
    "dotenv": "^17.4.2",
    "env-paths": "^4.0.0",
    "fastify": "^5.8.5",
    "pino": "^10.3.1",
    "selfsigned": "^5.5.0",
    "usb": "^2.17.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.0",
    "esbuild": "^0.28.0",
    "pino-pretty": "^13.1.3",
    "postject": "1.0.0-alpha.6",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3"
  }
}
